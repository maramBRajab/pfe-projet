# Copiez ce fichier vers .env ou exportez les variables avant de lancer le backend.
# Gmail : activez la validation en 2 etapes, puis creez un "mot de passe d'application".

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=votre.adresse@gmail.com
SPRING_MAIL_PASSWORD=mot_de_passe_application_16_caracteres

# Expediteur affiche dans l'email (optionnel)
MAIL_FROM=SmartAssign <votre.adresse@gmail.com>

# true = journalise le lien dans les logs si SMTP incomplet (developpement uniquement)
MAIL_DEV_LOG_RESET_LINK=true

# false en production lorsque SMTP est configure
# MAIL_DEV_LOG_RESET_LINK=false

# URL du frontend pour le lien de reinitialisation
# app.frontend.reset-password-url=http://localhost:4200/reset-password

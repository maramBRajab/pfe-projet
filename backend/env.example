# Copy this file to .env for local development, or export the variables before
# starting the backend. Never commit .env with real secrets.

# Server
SERVER_PORT=8082

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/affectation_db
DB_USERNAME=postgres
DB_PASSWORD=change_me

# JWT
# Use a strong random value. Base64 is supported by JwtService.
# Example generation:
#   PowerShell: [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }))
#   Linux:     openssl rand -base64 64
JWT_SECRET=change_me_generate_a_long_random_secret
JWT_EXPIRATION_MS=86400000

# Frontend links
FRONTEND_RESET_PASSWORD_URL=http://localhost:4200/reset-password
EMAIL_VERIFICATION_URL=http://localhost:4200/verify-email
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRATION_MINUTES=1440
EMAIL_VERIFICATION_REQUIRE_DELIVERY=true
EMAIL_VERIFICATION_CHECK_MX_RECORDS=true

# SMTP / Gmail
# For Gmail, enable 2-step verification and create an app password.
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your.address@gmail.com
SPRING_MAIL_PASSWORD=your_16_character_app_password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_SSL_ENABLE=false
SPRING_MAIL_SMTP_SSL_TRUST=smtp.gmail.com
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
SPRING_MAIL_SMTP_CONNECTION_TIMEOUT=15000
SPRING_MAIL_SMTP_TIMEOUT=15000
SPRING_MAIL_SMTP_WRITE_TIMEOUT=15000

# SmartAssign mail options
MAIL_ENABLED=true
MAIL_FROM=SmartAssign <your.address@gmail.com>
MAIL_DEV_LOG_RESET_LINK=true

# Optional demo/bootstrap accounts
# Keep disabled in production. If enabled for local demos, provide every password
# through environment variables and never commit a real .env file.
BOOTSTRAP_DEMO_USERS_ENABLED=false
BOOTSTRAP_DEMO_ADMIN_EMAIL=admin@smartassign.tn
BOOTSTRAP_DEMO_ADMIN_PASSWORD=change_me_admin_password
BOOTSTRAP_DEMO_MANAGER_EMAIL=manager@smartassign.tn
BOOTSTRAP_DEMO_MANAGER_PASSWORD=change_me_manager_password
BOOTSTRAP_DEMO_COLLAB_EMAIL=collab@smartassign.tn
BOOTSTRAP_DEMO_COLLAB_PASSWORD=change_me_collab_password

# Optional frontend smoke/e2e test credentials
SMOKE_ADMIN_EMAIL=admin@smartassign.tn
SMOKE_ADMIN_PASSWORD=change_me_admin_password
SMOKE_MANAGER_EMAIL=manager@smartassign.tn
SMOKE_MANAGER_PASSWORD=change_me_manager_password
SMOKE_COLLAB_EMAIL=collab@smartassign.tn
SMOKE_COLLAB_PASSWORD=change_me_collab_password
SMOKE_PUBLIC_PASSWORD=change_me_public_test_password

# Anthropic Claude manager IA fallback
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_API_MODEL=claude-sonnet-4-20250514

# JPA and scheduler
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
NOTIFICATIONS_SCHEDULER_ENABLED=false
NOTIFICATIONS_SCHEDULER_CRON=0 0 8 * * *
